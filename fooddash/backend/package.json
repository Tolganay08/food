{
  "name": "fooddash-backend",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://tolganay08.github.io/fooddash",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "node src/prisma/seed.js",
    "db:generate": "npx prisma generate",
    "db:reset": "npx prisma migrate reset --force && node src/prisma/seed.js",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build"
  },
  "prisma": {
    "seed": "node src/prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.4",
    "stripe": "^14.18.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0"
  }
}
